# ---------------------------------------------------------------------------
# Library Management System — environment variables
# Copy to ".env" and fill in real values. NEVER commit real secrets.
# In production, only these values change to point at real Azure — no code edits.
# ---------------------------------------------------------------------------

# SQL Server (docker-compose + backend connection string)
MSSQL_SA_PASSWORD=Your_strong_Password123
ConnectionStrings__SqlServer=Server=localhost,1433;Database=LmsDb;User Id=sa;Password=Your_strong_Password123;TrustServerCertificate=True;Encrypt=False

# Redis
ConnectionStrings__Redis=localhost:6379

# JWT
Jwt__Issuer=LMS.API
Jwt__Audience=LMS.Client
Jwt__SigningKey=replace-with-a-long-random-32+-character-secret
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=7

# Azure Blob Storage (Azurite locally). Swap for a real Azure connection string in prod.
BlobStorage__ConnectionString=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
BlobStorage__ContainerName=covers

# Azure Service Bus (emulator locally). Swap for a real Azure connection string in prod.
ServiceBus__ConnectionString=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;
ServiceBus__OverdueQueueName=overdue-alerts

# Background overdue checker
OverdueChecker__IntervalHours=24
